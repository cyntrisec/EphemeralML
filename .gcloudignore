# .gcloudignore — controls what gcloud uploads for Cloud Build.
# Must be kept tight to avoid multi-GB uploads.
# The verifier build only needs: Cargo.toml, Cargo.lock, common/, verifier-api/

# Rust build artifacts
target/
.target_codex/
.target_*/

# Git / IDE / OS
.git/
.github/
.vscode/
.idea/
.DS_Store
*.swp
*~

# Terraform
.terraform/
*.tfstate
*.tfstate.*

# Environment / secrets
.env
.env.*
keys/*_private*

# Large directories not needed for verifier build
test_assets/
examples/
scripts/
gateway-api/
site/
docs/
spec/
evidence/
attestation-evidence/
demo-artifacts/
demo-pack/
infra/
benchmark_results/
pilot-evidence/
nvidia-disclosures/
compliance/
AGENTS/
investor/

# Crates not needed for verifier (stubs created in Dockerfile)
client/
host/
enclave/

# AWS Nitro artifacts
*.eif
enclave.dockerfile

# Python
env/
venv/
__pycache__/

# Markdown (not needed for build)
*.md

# Claude workspace
.claude/
